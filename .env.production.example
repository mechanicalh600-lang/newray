# استقرار داخلی کارخانه (شبکه LAN)
# کپی به .env.production قبل از npm run build

VITE_SUPABASE_URL=http://192.168.1.50
VITE_SUPABASE_ANON_KEY=local-production-anon-key-change-me
VITE_INTERNAL_NETWORK=true
VITE_BASE_URL=/

# دستیار AI — فقط اگر اینترنت/outbound دارید
# VITE_GEMINI_API_KEY=

# --- سمت سرور (API، نه داخل بیلد Vite) ---
