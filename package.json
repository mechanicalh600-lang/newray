{
  "name": "newray",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "node scripts/local-api-server.mjs",
    "dev:stack": "node scripts/dev-stack.mjs",
    "db:check": "powershell -File scripts/check-db-schema.ps1",
    "db:migrate": "powershell -File scripts/apply-all-migrations.ps1",
    "db:migrate:process": "node scripts/run-migration-process-modules.mjs",
    "db:migrate:process-form": "node scripts/run-migration-process-form-schema.mjs",
    "db:hash-passwords": "node scripts/migrate-passwords.mjs",
    "db:smoke": "node scripts/smoke-test-api.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "build:liara": "node scripts/build-liara-yazl.js",
    "build:liara:archiver": "node scripts/build-liara-react.js",
    "build:liara:static": "node scripts/build-liara.js"
  },
  "dependencies": {
    "@google/genai": "*",
    "@supabase/supabase-js": "^2.39.7",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "html2pdf.js": "^0.10.1",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.24",
    "gh-pages": "^6.1.1",
    "pg": "^8.22.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "yazl": "^3.3.1"
  }
}
